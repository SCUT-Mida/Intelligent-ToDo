{
  "$schema": "repo-navigator/v1",
  "scanRoots": [
    "D:\\Coding"
  ],
  "scanDepth": 3,
  "excludePatterns": [
    "node_modules",
    ".git",
    "dist",
    "out",
    "build",
    "__pycache__",
    ".venv",
    "vendor"
  ],
  "commandTemplates": {
    "default": "git pull; opencode",
    "update": "git pull --prune",
    "work": "git pull; opencode",
    "code": "git pull; code .",
    "build": "git pull; npm run build"
  },
  "defaultTemplate": "default",
  "openIn": "new-tab",
  "fallbackToPowerShellExe": true
}
